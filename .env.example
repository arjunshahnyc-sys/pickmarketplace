# ==============================================================================
# PICK MARKETPLACE - ENVIRONMENT VARIABLES
# ==============================================================================

# Database URL (SQLite for development)
DATABASE_URL="file:./dev.db"

# Best Buy Products API
# Get a free API key at: https://developer.bestbuy.com/
# Free tier: 50,000 requests/day
# Required for Best Buy product search
BESTBUY_API_KEY=your_bestbuy_api_key_here

# ==============================================================================
# NOTES:
# ==============================================================================
#
# REQUIRED API KEYS:
# - BESTBUY_API_KEY: Required for Best Buy product search
#   - Without this key, Best Buy results will be skipped
#   - Sign up at https://developer.bestbuy.com/
#   - Free tier provides 50,000 requests per day
#
# WORKING WITHOUT API KEYS:
# - Target search works without any API key (uses public Redsky API)
# - Walmart search works without any API key (uses public search endpoint)
# - Best Buy search requires an API key
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Replace placeholder values with your actual API keys
# 3. Restart the dev server: npm run dev
#
# ==============================================================================
